{
  "name": "journal-cron",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create journal_db",
    "db:migrate": "wrangler d1 execute journal_db --file=schema.sql --remote",
    "db:migrate:local": "wrangler d1 execute journal_db --file=schema.sql --local"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "typescript": "^5.5.2",
    "wrangler": "^3.60.0"
  }
}
