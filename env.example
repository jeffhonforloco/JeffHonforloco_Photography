# Environment Variables for Jeff Honforloco Photography Platform
# Copy this file to .env.local and fill in your actual values

# Admin Authentication (CRITICAL: Change these in production!)
VITE_ADMIN_USERNAME=jeff.admin
VITE_ADMIN_PASSWORD_HASH=8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92
VITE_ADMIN_SALT=jeff-honforloco-salt-2024

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Analytics Configuration
VITE_GA_TRACKING_ID=your-google-analytics-id
VITE_GTM_ID=your-google-tag-manager-id

# Email Configuration
# VITE_EMAIL_SERVICE_URL — URL of the send-contact-email Supabase edge function
# e.g. https://your-project-ref.supabase.co/functions/v1/send-contact-email
VITE_EMAIL_SERVICE_URL=your-supabase-send-contact-email-function-url
VITE_CONTACT_EMAIL=info@jeffhonforlocophotos.com

# AI Sales Chatbot
# VITE_CHATBOT_URL — URL of the sales-chatbot Supabase edge function
# e.g. https://your-project-ref.supabase.co/functions/v1/sales-chatbot
VITE_CHATBOT_URL=your-supabase-sales-chatbot-function-url

# Security Settings
VITE_CSRF_SECRET=your-csrf-secret-key
VITE_SESSION_SECRET=your-session-secret-key

# Development Settings
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# ── Supabase Edge Function Secrets ───────────────────────────────────────────
# Set these in the Supabase dashboard → Project Settings → Edge Functions → Secrets
# Do NOT put these in .env.local — they are server-side only.
#
# ANTHROPIC_API_KEY=your-anthropic-api-key          (required for AI chatbot)
# RESEND_API_KEY=your-resend-api-key                (required for email delivery)
# BRAVE_SEARCH_API_KEY=your-brave-search-api-key    (optional — enables web search in chatbot)
#   Get a free key at: https://api.search.brave.com/register
