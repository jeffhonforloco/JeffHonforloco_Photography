# Environment Variables for Jeff Honforloco Photography Platform
# Copy this file to .env.local and fill in your actual values

# Admin Authentication (CRITICAL: Change these in production!)
VITE_ADMIN_USERNAME=jeff.admin
VITE_ADMIN_PASSWORD_HASH=8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92
VITE_ADMIN_SALT=jeff-honforloco-salt-2024

# Cloudflare Worker — all API calls, email, and AI chatbot route through here
# Find your worker URL in: Cloudflare Dashboard → Workers & Pages → api-jeffhonforloco-photography → Overview
VITE_API_BASE_URL=https://api-jeffhonforloco-photography.YOUR_SUBDOMAIN.workers.dev/api/v1
VITE_CHATBOT_URL=https://api-jeffhonforloco-photography.YOUR_SUBDOMAIN.workers.dev/api/v1/chat

# Analytics Configuration
VITE_GA_TRACKING_ID=your-google-analytics-id
VITE_GTM_ID=your-google-tag-manager-id

# Contact email displayed to visitors
VITE_CONTACT_EMAIL=info@jeffhonforlocophotos.com

# Security Settings
VITE_CSRF_SECRET=your-csrf-secret-key
VITE_SESSION_SECRET=your-session-secret-key

# Development Settings
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# ── Cloudflare Worker Secrets ─────────────────────────────────────────────────
# Set these in Cloudflare Dashboard → Workers & Pages → api-jeffhonforloco-photography
#   → Settings → Variables → Add secret (encrypted)
# Do NOT commit these values.
#
# ANTHROPIC_API_KEY   — Anthropic API key (AI chatbot + daily blog posts)
# RESEND_API_KEY      — Resend API key (all outbound email)
# JWT_SECRET          — Long random string (32+ chars) for admin auth tokens
# ADMIN_EMAIL         — info@jeffhonforlocophotos.com
# ALLOWED_ORIGIN      — https://jeffhonforlocophotos.com
